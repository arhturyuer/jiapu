.profile-page { padding-bottom: calc(56rpx + env(safe-area-inset-bottom)); }
.profile-card { padding: 32rpx; display: flex; align-items: flex-start; justify-content: flex-start; }
.avatar-column { width: 144rpx; flex: 0 0 144rpx; }
.avatar-button { width: 100%; display: flex; flex-direction: column; align-items: flex-start; justify-content: flex-start; line-height: 1; }
.avatar-button-active { opacity: 0.72; }
.avatar-button-busy { opacity: 0.72; }
.profile-avatar { width: 144rpx; height: 144rpx; border-radius: 44rpx; }
.profile-placeholder { display: flex; align-items: center; justify-content: center; color: #245C4A; background: #E4EFEA; font-size: 52rpx; font-weight: 600; }
.avatar-edit { width: 100%; margin-top: 12rpx; display: block; color: #245C4A; font-size: 24rpx; line-height: 1.4; text-align: center; }
.avatar-status { width: 164rpx; margin-top: 8rpx; display: block; color: #65706A; font-size: 21rpx; line-height: 1.45; text-align: center; transform: translateX(-10rpx); }
.avatar-status-approved { color: #245C4A; }
.avatar-status-pending, .avatar-status-uploading, .avatar-status-saving { color: #8A641F; }
.avatar-status-rejected, .avatar-status-failed { color: #A14132; }
.avatar-retry { width: 100%; margin-top: 8rpx; display: block; color: #A14132; font-size: 23rpx; text-align: center; text-decoration: underline; }
.profile-form { width: calc(100% - 172rpx); min-width: 0; margin-left: 28rpx; flex: none; text-align: left; }
.profile-label { display: block; color: #65706A; font-size: 26rpx; line-height: 1.4; }
.nickname-input { width: 100%; height: 84rpx; margin: 10rpx 0 0; padding: 0 20rpx; display: block; background: #F3F2EC; border: 2rpx solid #D8DED9; border-radius: 18rpx; text-align: left; }
.save-profile { width: 100%; min-height: 76rpx; margin: 16rpx 0 0; font-size: 28rpx; }
.save-profile-active { background: #194636; transform: translateY(1rpx); }
.save-profile-disabled { color: rgba(255, 255, 255, 0.8); background: #8BA99D; box-shadow: none; }
.section-block { margin-top: 40rpx; }
.setting-list { padding: 0 24rpx; }
.setting-row { min-height: 116rpx; display: flex; align-items: center; justify-content: space-between; border-bottom: 2rpx solid #EEF0ED; }
.setting-row:last-child { border-bottom: none; }
.setting-title, .setting-desc { display: block; }
.setting-title { font-weight: 600; }
.setting-desc { margin-top: 6rpx; color: #65706A; font-size: 26rpx; }
.setting-arrow { color: #9AA39E; font-size: 48rpx; }
.version-text { margin-top: 48rpx; display: block; color: #9AA39E; font-size: 24rpx; text-align: center; }
.family-option { min-height: 108rpx; padding: 20rpx; display: flex; align-items: center; justify-content: space-between; border-bottom: 2rpx solid #EEF0ED; }
.family-option.selected { background: #E4EFEA; border-radius: 20rpx; }
.family-option-name, .family-option-role { display: block; }
.family-option-name { font-weight: 600; }
.family-option-role { margin-top: 6rpx; color: #65706A; font-size: 26rpx; }
.selected-text { color: #245C4A; font-size: 26rpx; }
.create-family-button { width: 100%; margin-top: 28rpx; }
