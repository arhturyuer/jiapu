.family-page { padding-bottom: calc(56rpx + env(safe-area-inset-bottom)); }
.empty-action { width: 360rpx; }
.family-hero { padding: 32rpx; }
.family-hero-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 20rpx; }
.family-name, .family-role { display: block; }
.family-name { font-size: 44rpx; font-weight: 600; }
.family-role { margin-top: 8rpx; color: #65706A; font-size: 26rpx; }
.invite-button { min-width: 168rpx; height: 76rpx; padding: 0 22rpx; color: #FFFFFF; background: #245C4A; font-size: 28rpx; }
.family-description { margin-top: 24rpx; display: block; color: #65706A; line-height: 1.6; }
.progress-track { height: 12rpx; margin-top: 28rpx; overflow: hidden; background: #E1E5E1; border-radius: 12rpx; }
.progress-value { height: 100%; background: #245C4A; border-radius: 12rpx; }
.progress-text { margin-top: 12rpx; display: block; color: #65706A; font-size: 24rpx; }
.stats-grid { margin-top: 20rpx; display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.stat-card { min-height: 144rpx; padding: 24rpx; display: flex; flex-direction: column; justify-content: center; }
.stat-value { color: #245C4A; font-size: 44rpx; font-weight: 600; }
.stat-label { margin-top: 4rpx; color: #65706A; font-size: 26rpx; }
.section-block { margin-top: 40rpx; }
.change-card { margin-bottom: 16rpx; padding: 24rpx; }
.change-copy { display: flex; flex-direction: column; }
.change-title { font-weight: 600; }
.change-requester { margin-top: 8rpx; color: #65706A; font-size: 26rpx; }
.review-actions { margin-top: 20rpx; display: flex; justify-content: flex-end; gap: 12rpx; }
.review-button { width: 144rpx; height: 68rpx; font-size: 26rpx; }
.review-button.reject { color: #B43D3D; background: #FBEDEC; }
.review-button.approve { color: #FFFFFF; background: #245C4A; }
.collaborator-scroll { width: calc(100vw - 32rpx); }
.collaborator-row { display: flex; gap: 16rpx; padding-right: 32rpx; }
.collaborator-card { flex: none; width: 200rpx; min-height: 220rpx; padding: 24rpx 16rpx; display: flex; flex-direction: column; align-items: center; text-align: center; }
.collaborator-avatar { width: 84rpx; height: 84rpx; border-radius: 28rpx; }
.collaborator-placeholder { display: flex; align-items: center; justify-content: center; color: #245C4A; background: #E4EFEA; font-weight: 600; }
.collaborator-name { max-width: 168rpx; margin-top: 14rpx; overflow: hidden; font-weight: 600; text-overflow: ellipsis; white-space: nowrap; }
.collaborator-role { margin-top: 4rpx; color: #65706A; font-size: 24rpx; }
.activity-list { padding: 8rpx 24rpx; }
.activity-row { min-height: 104rpx; display: flex; align-items: flex-start; padding: 22rpx 0; border-bottom: 2rpx solid #EEF0ED; }
.activity-row:last-child { border-bottom: none; }
.activity-dot { width: 16rpx; height: 16rpx; margin: 12rpx 20rpx 0 0; flex: none; background: #245C4A; border-radius: 50%; }
.activity-copy { display: flex; flex-direction: column; }
.activity-summary { line-height: 1.5; }
.activity-time { margin-top: 6rpx; color: #65706A; font-size: 24rpx; }
.empty-activity { padding: 40rpx; color: #65706A; text-align: center; }
.graph-button { width: 100%; margin-top: 40rpx; }
.share-help { margin-bottom: 24rpx; display: block; color: #65706A; line-height: 1.6; }
.share-role { margin-bottom: 16rpx; padding: 24rpx; display: flex; flex-direction: column; border: 2rpx solid #D8DED9; border-radius: 22rpx; }
.share-role.selected { background: #E4EFEA; border-color: #245C4A; }
.share-role-title { font-weight: 600; }
.share-role-desc { margin-top: 6rpx; color: #65706A; font-size: 26rpx; }
.share-button { width: 100%; margin-top: 28rpx; }
