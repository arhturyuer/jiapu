.tree-page {
  height: calc(100vh - 0px);
  overflow: hidden;
  background: #F7F4EC;
}

.empty-action {
  width: 360rpx;
}

.tree-toolbar {
  height: 112rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #F7F4EC;
  border-bottom: 2rpx solid rgba(36, 92, 74, 0.08);
}

.family-switch {
  max-width: 210rpx;
  height: 72rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  background: #FFFEFA;
  border: 2rpx solid #D8DED9;
  border-radius: 20rpx;
}

.family-switch-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 28rpx;
  font-weight: 600;
}

.family-switch-arrow {
  margin-left: 8rpx;
  color: #65706A;
}

.mode-switch {
  flex: 1;
  height: 72rpx;
  padding: 6rpx;
  display: flex;
  align-items: center;
  overflow: hidden;
  background: #E9EAE4;
  border-radius: 20rpx;
}

.mode-item {
  flex: 1;
  height: 60rpx;
  padding: 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  color: #65706A;
  border-radius: 16rpx;
  font-size: 26rpx;
  white-space: nowrap;
}

.mode-item.active {
  color: #245C4A;
  background: #FFFEFA;
  font-weight: 600;
}

.toolbar-share {
  width: 88rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #245C4A;
  background: #FFFEFA;
  border: 2rpx solid #D8DED9;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.graph-viewport {
  width: 100%;
  height: calc(100vh - 112rpx - 120rpx);
  overflow: hidden;
  background-color: #F7F4EC;
  background-image: radial-gradient(rgba(36, 92, 74, 0.09) 1rpx, transparent 1rpx);
  background-size: 32rpx 32rpx;
}

.graph-controls {
  position: fixed;
  right: 24rpx;
  bottom: calc(206rpx + env(safe-area-inset-bottom));
  z-index: 22;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.graph-control {
  width: 72rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #245C4A;
  background: rgba(255, 254, 250, 0.96);
  border: 2rpx solid #D8DED9;
  border-radius: 18rpx;
  box-shadow: 0 6rpx 18rpx rgba(36, 59, 49, 0.09);
  font-size: 34rpx;
  font-weight: 600;
}

.graph-control-text {
  font-size: 22rpx;
  font-weight: 500;
}

.graph-movable {
  display: block;
  will-change: transform;
}

.graph-canvas {
  position: relative;
  min-width: 750rpx;
  min-height: 900rpx;
  background: transparent;
}

.relation-line {
  position: absolute;
  z-index: 1;
  height: 4rpx;
  overflow: hidden;
  pointer-events: none;
  transform-origin: left center;
  background: #A6B7AE;
  border-radius: 999rpx;
}

.relation-spouse {
  height: 5rpx;
  background: #829D91;
}

.relation-trunk,
.relation-drop {
  height: 4rpx;
  background: #A6B7AE;
}

.relation-rail {
  height: 3rpx;
  background: #BEC9C3;
}

.relation-flow {
  z-index: 2;
  height: 6rpx;
  background: #6F9E89;
}

.flow-runner {
  width: 100%;
  height: 100%;
  opacity: 0;
  background: linear-gradient(90deg, #245C4A 0%, #3E8069 72%, #D7E9E1 100%);
  border-radius: 999rpx;
  transform: scaleX(0);
  transform-origin: left center;
  will-change: transform, opacity;
  animation-duration: 2.4s;
  animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  animation-iteration-count: infinite;
}

.flow-runner.flow-step-0 { animation-name: family-flow-pulse-0; }
.flow-runner.flow-step-1 { animation-name: family-flow-pulse-1; }
.flow-runner.flow-step-2 { animation-name: family-flow-pulse-2; }
.flow-runner.flow-step-3 { animation-name: family-flow-pulse-3; }

@keyframes family-flow-pulse-0 {
  0% { opacity: 0; transform: scaleX(0); }
  2% { opacity: 1; transform: scaleX(0); }
  20% { opacity: 1; transform: scaleX(1); }
  24%, 100% { opacity: 0; transform: scaleX(1); }
}

@keyframes family-flow-pulse-1 {
  0%, 25% { opacity: 0; transform: scaleX(0); }
  27% { opacity: 1; transform: scaleX(0); }
  45% { opacity: 1; transform: scaleX(1); }
  49%, 100% { opacity: 0; transform: scaleX(1); }
}

@keyframes family-flow-pulse-2 {
  0%, 50% { opacity: 0; transform: scaleX(0); }
  52% { opacity: 1; transform: scaleX(0); }
  70% { opacity: 1; transform: scaleX(1); }
  74%, 100% { opacity: 0; transform: scaleX(1); }
}

@keyframes family-flow-pulse-3 {
  0%, 75% { opacity: 0; transform: scaleX(0); }
  77% { opacity: 1; transform: scaleX(0); }
  95% { opacity: 1; transform: scaleX(1); }
  99%, 100% { opacity: 0; transform: scaleX(1); }
}

.family-junction {
  position: absolute;
  z-index: 3;
  width: 14rpx;
  height: 14rpx;
  pointer-events: none;
  background: #829D91;
  border: 3rpx solid #F7F4EC;
  border-radius: 50%;
}

.family-junction.is-active {
  background: #245C4A;
  border-color: #D7E9E1;
  transform: scale(1.12);
}

.person-node {
  position: absolute;
  z-index: 4;
  width: 168rpx;
  min-height: 116rpx;
  padding: 14rpx 12rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #FFFEFA;
  border: 2rpx solid #D8DED9;
  border-radius: 24rpx;
}

.person-node.is-viewpoint {
  border: 5rpx solid #245C4A;
  box-shadow: 0 0 0 8rpx rgba(36, 92, 74, 0.12);
}

.person-node.is-selected {
  border-color: #C18A32;
  box-shadow: 0 0 0 7rpx rgba(193, 138, 50, 0.16);
}

.person-node.is-viewpoint.is-selected {
  border-color: #245C4A;
  box-shadow: 0 0 0 8rpx rgba(193, 138, 50, 0.2), 0 0 0 15rpx rgba(36, 92, 74, 0.12);
}

.node-avatar {
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 6rpx;
  border-radius: 18rpx;
}

.node-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #245C4A;
  background: #E4EFEA;
  font-size: 26rpx;
  font-weight: 600;
}

.node-name {
  max-width: 144rpx;
  overflow: hidden;
  color: #202824;
  font-size: 28rpx;
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.node-meta {
  max-width: 144rpx;
  margin-top: 2rpx;
  overflow: hidden;
  color: #65706A;
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.branch-count {
  position: absolute;
  right: -18rpx;
  bottom: -22rpx;
  min-width: 72rpx;
  height: 38rpx;
  padding: 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFEFA;
  background: #245C4A;
  border: 4rpx solid #F7F4EC;
  border-radius: 22rpx;
  font-size: 20rpx;
  font-weight: 600;
  white-space: nowrap;
}

.node-action-trigger {
  position: absolute;
  top: -22rpx;
  right: -20rpx;
  z-index: 6;
  width: 52rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFEFA;
  background: #C18A32;
  border: 4rpx solid #F7F4EC;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: -2rpx;
}

.graph-movable.zoom-compact .node-meta {
  display: none;
}

.graph-movable.zoom-overview .node-avatar,
.graph-movable.zoom-overview .node-meta {
  display: none;
}

.graph-movable.zoom-overview .person-node {
  justify-content: center;
  padding: 12rpx;
  background: #FFFEFA;
  border-width: 4rpx;
  box-shadow: none;
}

.graph-movable.zoom-overview .node-name {
  font-size: 32rpx;
}

.graph-movable.zoom-overview .relation-line:not(.relation-flow) {
  opacity: 0.72;
}

.graph-help {
  position: fixed;
  left: 50%;
  bottom: calc(128rpx + env(safe-area-inset-bottom));
  z-index: 20;
  max-width: 620rpx;
  padding: 14rpx 24rpx;
  transform: translateX(-50%);
  color: #65706A;
  background: rgba(255, 254, 250, 0.94);
  border: 2rpx solid #D8DED9;
  border-radius: 40rpx;
  font-size: 24rpx;
  white-space: nowrap;
}

.graph-empty {
  height: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.graph-empty-title {
  margin-bottom: 12rpx;
  font-size: 36rpx;
  font-weight: 600;
}

.family-option,
.perspective-option {
  min-height: 104rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 2rpx solid #EEF0ED;
}

.family-option.selected {
  background: #E4EFEA;
  border-radius: 20rpx;
}

.family-option-name,
.family-option-role {
  display: block;
}

.family-option-name {
  font-weight: 600;
}

.family-option-role,
.family-option-check {
  margin-top: 6rpx;
  color: #65706A;
  font-size: 26rpx;
}

.sheet-button {
  width: 100%;
  margin-top: 28rpx;
}

.person-sheet-head {
  margin-bottom: 28rpx;
  display: flex;
  align-items: center;
}

.person-sheet-avatar {
  width: 112rpx;
  height: 112rpx;
  margin-right: 24rpx;
  border-radius: 32rpx;
}

.person-sheet-placeholder,
.small-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #245C4A;
  background: #E4EFEA;
  font-weight: 600;
}

.person-sheet-copy {
  display: flex;
  flex-direction: column;
}

.person-sheet-name {
  margin-bottom: 8rpx;
  font-size: 42rpx;
  font-weight: 600;
}

.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.action-cell {
  min-height: 136rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: #F7F4EC;
  border: 2rpx solid #E3E6E2;
  border-radius: 22rpx;
}

.action-cell-wide {
  grid-column: 1 / -1;
}

.action-title {
  margin-bottom: 8rpx;
  font-weight: 600;
}

.action-desc {
  color: #65706A;
  font-size: 24rpx;
}

.perspective-sheet {
  height: 72vh;
}

.person-search {
  height: 88rpx;
  padding: 0 24rpx;
  background: #F3F2EC;
  border: 2rpx solid #D8DED9;
  border-radius: 22rpx;
}

.perspective-list {
  height: calc(72vh - 190rpx);
  margin-top: 16rpx;
}

.perspective-option {
  justify-content: flex-start;
}

.small-avatar {
  width: 64rpx;
  height: 64rpx;
  margin-right: 20rpx;
  border-radius: 20rpx;
}

.relation-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.relation-option {
  height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #245C4A;
  background: #E4EFEA;
  border: 2rpx solid #C5D8CF;
  border-radius: 24rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.share-summary {
  padding: 28rpx;
  display: flex;
  flex-direction: column;
}

.share-summary-title {
  font-size: 34rpx;
  font-weight: 600;
}

.share-summary-desc {
  margin-top: 10rpx;
  color: #65706A;
  font-size: 26rpx;
}

.share-label {
  margin: 32rpx 0 16rpx;
  display: block;
  font-weight: 600;
}

.share-role-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.share-role {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  border: 2rpx solid #D8DED9;
  border-radius: 22rpx;
}

.share-role.selected {
  background: #E4EFEA;
  border-color: #245C4A;
}

.share-role-title {
  font-weight: 600;
}

.share-role-desc {
  margin-top: 6rpx;
  color: #65706A;
  font-size: 26rpx;
}
